  "scripts": {
    "dev": "next dev",
    "build": "pnpm registry:build && next build",
    "start": "next start",
    "preview": "pnpm registry:build && next build && next start",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint --fix . --cache --cache-location .eslintcache",
    "check-types": "tsc --noEmit --pretty",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,md,mdx}\" --cache",
    "registry:build": "bun run ./src/scripts/build-registry.mts && shadcn build",
    "registry:validate": "shadcn registry validate ./public/r/registry.json",
    "capture": "bun run ./src/scripts/capture.mts",
    "icons:dev": "bun run ./src/scripts/build-icons.ts --watch",
    "icons:build": "bun run ./src/scripts/build-icons.ts",
    "generate-libphonenumber-metadata": "libphonenumber-metadata-generator ./src/assets/libphonenumber.metadata.json --countries VN --extended",
    "upgrade:next": "npx @next/codemod@latest upgrade latest",
    "upgrade:tailwind": "npx @tailwindcss/upgrade@latest",
    "prepare": "husky"
  },
